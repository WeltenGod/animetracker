<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anime Watch Party Sync</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white min-h-screen p-8">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl font-bold mb-8 text-center text-blue-400">Anime Watch Party Sync</h1>

        <!-- Connected Users Section -->
        <div class="bg-gray-800 p-6 rounded-lg mb-8 shadow-lg">
            <h2 class="text-2xl font-semibold mb-4 border-b border-gray-700 pb-2">Connected Friends</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <% if (users.length === 0) { %>
                    <p class="text-gray-400 col-span-3">No users connected yet. Have your friends click the links below to connect their accounts.</p>
                <% } else { %>
                    <% users.forEach(user => { %>
                        <div class="bg-gray-700 p-4 rounded-md">
                            <span class="font-bold text-lg"><%= user.name %></span>
                            <div class="mt-2 text-sm flex flex-col gap-1">
                                <span class="<%= user.anilist_token ? 'text-green-400' : 'text-red-400' %>">
                                    AniList: <%= user.anilist_token ? 'Connected' : 'Disconnected' %>
                                </span>
                                <span class="<%= user.mal_token ? 'text-green-400' : 'text-red-400' %>">
                                    MyAnimeList: <%= user.mal_token ? 'Connected' : 'Disconnected' %>
                                </span>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <div class="mt-6 flex flex-wrap gap-4 justify-center">
                <a href="/auth/anilist" class="bg-blue-600 hover:bg-blue-700 px-6 py-2 rounded-md font-semibold transition">Connect AniList</a>
                <a href="/auth/mal" class="bg-indigo-600 hover:bg-indigo-700 px-6 py-2 rounded-md font-semibold transition" onclick="return confirmMAL()">Connect MyAnimeList</a>
            </div>
            <p class="text-xs text-gray-500 mt-2 text-center">Note: Please connect AniList FIRST before connecting MyAnimeList so we know your username!</p>
        </div>

        <!-- Sync Section -->
        <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
            <h2 class="text-2xl font-semibold mb-4 border-b border-gray-700 pb-2">Sync Progress</h2>

            <div class="mb-6">
                <label class="block text-sm font-medium mb-2">Search Anime</label>
                <div class="flex gap-2">
                    <input type="text" id="searchInput" class="flex-1 bg-gray-700 border border-gray-600 rounded-md px-4 py-2 focus:outline-none focus:border-blue-500" placeholder="e.g., Attack on Titan">
                    <button onclick="searchAnime()" class="bg-gray-600 hover:bg-gray-500 px-4 py-2 rounded-md transition">Search</button>
                </div>
            </div>

            <div id="searchResults" class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6"></div>

            <div id="syncForm" class="hidden mt-8 border-t border-gray-700 pt-6">
                <div class="flex items-end gap-4">
                    <div class="flex-1">
                        <label class="block text-sm font-medium mb-2">Selected Anime</label>
                        <input type="text" id="selectedAnimeName" disabled class="w-full bg-gray-700 border border-gray-600 rounded-md px-4 py-2 opacity-70">
                        <input type="hidden" id="selectedAnilistId">
                        <input type="hidden" id="selectedMalId">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Episode</label>
                        <input type="number" id="episodeNumber" min="1" class="w-24 bg-gray-700 border border-gray-600 rounded-md px-4 py-2 focus:outline-none focus:border-blue-500" value="1">
                    </div>
                    <button onclick="syncProgress()" id="syncBtn" class="bg-green-600 hover:bg-green-700 px-8 py-2 rounded-md font-bold transition">Sync to All</button>
                </div>

                <div id="syncStatus" class="mt-4 text-sm whitespace-pre-line p-4 bg-gray-900 rounded-md hidden border border-gray-700"></div>
            </div>
        </div>
    </div>

    <script>
        function confirmMAL() {
            // Because MAL doesn't easily provide a reliable unique username linked across both,
            // we rely on the user having connected AniList first so the session knows who they are.
            alert("Ensure you have connected your AniList account on this browser first, or are logging into MAL right after!");
            return true;
        }

        async function searchAnime() {
            const query = document.getElementById('searchInput').value;
            if (!query) return;

            const resultsContainer = document.getElementById('searchResults');
            resultsContainer.innerHTML = '<p class="col-span-full text-center text-gray-400">Searching...</p>';

            try {
                const res = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
                const animeList = await res.json();

                resultsContainer.innerHTML = '';

                if (animeList.length === 0) {
                    resultsContainer.innerHTML = '<p class="col-span-full text-center text-gray-400">No results found.</p>';
                    return;
                }

                animeList.forEach(anime => {
                    const title = anime.title.english || anime.title.romaji;
                    const div = document.createElement('div');
                    div.className = 'cursor-pointer hover:opacity-80 transition transform hover:scale-105';
                    div.innerHTML = `
                        <img src="${anime.coverImage.medium}" alt="${title}" class="w-full h-48 object-cover rounded-md mb-2 shadow-md">
                        <p class="text-xs text-center truncate px-1" title="${title}">${title}</p>
                    `;
                    div.onclick = () => selectAnime(anime.id, anime.idMal, title);
                    resultsContainer.appendChild(div);
                });
            } catch (e) {
                resultsContainer.innerHTML = '<p class="col-span-full text-center text-red-400">Failed to search. Check console.</p>';
            }
        }

        function selectAnime(anilistId, malId, title) {
            document.getElementById('selectedAnilistId').value = anilistId;
            document.getElementById('selectedMalId').value = malId || '';
            document.getElementById('selectedAnimeName').value = title;
            document.getElementById('syncForm').classList.remove('hidden');
            document.getElementById('syncStatus').classList.add('hidden');
        }

        async function syncProgress() {
            const anilistId = document.getElementById('selectedAnilistId').value;
            const malId = document.getElementById('selectedMalId').value;
            const episode = document.getElementById('episodeNumber').value;
            const btn = document.getElementById('syncBtn');
            const statusDiv = document.getElementById('syncStatus');

            if (!anilistId || !episode) return alert("Please select an anime and episode number.");

            btn.disabled = true;
            btn.innerText = "Syncing...";
            btn.classList.replace('bg-green-600', 'bg-gray-600');
            statusDiv.classList.remove('hidden');
            statusDiv.innerText = "Syncing in progress, please wait...";

            try {
                const res = await fetch('/api/sync', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ anilistId, malId, episode })
                });

                const data = await res.json();
                let output = "Sync Results:\n----------------\n";

                data.results.forEach(r => {
                    output += `User: ${r.user}\n  AniList: ${r.anilist}\n  MAL: ${r.mal}\n\n`;
                });

                statusDiv.innerText = output;
                statusDiv.classList.add('text-green-300');
            } catch (e) {
                statusDiv.innerText = "Critical error occurred during sync. Check console.";
                statusDiv.classList.add('text-red-400');
            } finally {
                btn.disabled = false;
                btn.innerText = "Sync to All";
                btn.classList.replace('bg-gray-600', 'bg-green-600');
            }
        }
    </script>
</body>
</html>