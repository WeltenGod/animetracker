<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anime Watch Party Sync</title>
    <style>
        body { font-family: sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; }
        .success { color: green; margin-bottom: 20px; }
        .error { color: red; margin-bottom: 20px; }
        .card { border: 1px solid #ccc; padding: 15px; margin-bottom: 20px; border-radius: 5px; }
        .user-list { list-style: none; padding: 0; }
        .user-list li { margin-bottom: 10px; }
        .search-results { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px; margin-top: 20px; }
        .anime-card { border: 1px solid #eee; padding: 10px; text-align: center; cursor: pointer; border-radius: 5px; }
        .anime-card:hover { background-color: #f9f9f9; }
        .anime-card.selected { border-color: #007bff; background-color: #e9f5ff; }
        .anime-card img { max-width: 100%; height: auto; border-radius: 3px; }
        .sync-section { margin-top: 20px; display: none; padding: 15px; background: #f0f0f0; border-radius: 5px; }
        .loader { display: none; font-style: italic; color: #666; }
    </style>
</head>
<body>
    <h1>Anime Watch Party Sync</h1>

    <% if (successMsg) { %>
        <div class="success">Success: <%= successMsg %></div>
    <% } %>

    <div class="card">
        <h2>Connect Accounts</h2>
        <ul>
            <li><a href="/auth/anilist">Connect AniList</a></li>
        </ul>
    </div>

    <div class="card">
        <h2>Connected Users</h2>
        <% if (users && users.length > 0) { %>
            <ul class="user-list">
                <% users.forEach(user => { %>
                    <li>
                        <label>
                            <input type="checkbox" name="selectedUsers" value="<%= user.id %>" checked>
                            <%= user.name %>
                        </label>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No users connected yet. Please connect an account above.</p>
        <% } %>
    </div>

    <div class="card">
        <h2>Search Anime</h2>
        <div style="display: flex; gap: 10px;">
            <input type="text" id="searchInput" placeholder="Enter anime title..." style="flex-grow: 1; padding: 8px;">
            <button id="searchBtn" style="padding: 8px 15px;">Search</button>
        </div>
        <div id="searchLoader" class="loader">Searching...</div>
        <div id="searchResults" class="search-results"></div>
    </div>

    <div id="syncSection" class="sync-section">
        <h3>Sync Selected Anime</h3>
        <p id="selectedAnimeTitle" style="font-weight: bold;"></p>
        <input type="hidden" id="selectedAnimeId">

        <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 15px;">
            <label for="episodeInput">Episode watched:</label>
            <input type="number" id="episodeInput" min="1" value="1" style="padding: 5px; width: 60px;">
        </div>

        <button id="syncBtn" style="padding: 10px 20px; background-color: #007bff; color: white; border: none; border-radius: 3px; cursor: pointer;">Sync to Selected Users</button>
        <div id="syncLoader" class="loader" style="margin-top: 10px;">Syncing...</div>
        <div id="syncResult" style="margin-top: 10px;"></div>
    </div>

    <script>
        const searchInput = document.getElementById('searchInput');
        const searchBtn = document.getElementById('searchBtn');
        const searchLoader = document.getElementById('searchLoader');
        const searchResults = document.getElementById('searchResults');

        const syncSection = document.getElementById('syncSection');
        const selectedAnimeTitle = document.getElementById('selectedAnimeTitle');
        const selectedAnimeIdInput = document.getElementById('selectedAnimeId');

        const episodeInput = document.getElementById('episodeInput');
        const syncBtn = document.getElementById('syncBtn');
        const syncLoader = document.getElementById('syncLoader');
        const syncResult = document.getElementById('syncResult');

        // Search Anime
        searchBtn.addEventListener('click', async () => {
            const query = searchInput.value.trim();
            if (!query) return;

            searchLoader.style.display = 'block';
            searchResults.innerHTML = '';
            syncSection.style.display = 'none';

            try {
                const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
                const animeList = await response.json();

                if (animeList.length === 0) {
                    searchResults.innerHTML = '<p>No anime found.</p>';
                } else {
                    animeList.forEach(anime => {
                        const title = anime.title.english || anime.title.romaji;
                        const div = document.createElement('div');
                        div.className = 'anime-card';
                        div.innerHTML = `
                            <img src="${anime.coverImage.large}" alt="${title}">
                            <div style="margin-top: 10px; font-weight: bold;">${title}</div>
                        `;

                        div.addEventListener('click', () => {
                            // Deselect others
                            document.querySelectorAll('.anime-card').forEach(c => c.classList.remove('selected'));
                            div.classList.add('selected');

                            // Show Sync Section
                            selectedAnimeIdInput.value = anime.id;
                            selectedAnimeTitle.textContent = title;
                            syncSection.style.display = 'block';
                            syncResult.innerHTML = ''; // clear previous results
                            syncSection.scrollIntoView({ behavior: 'smooth' });
                        });

                        searchResults.appendChild(div);
                    });
                }
            } catch (err) {
                searchResults.innerHTML = '<p class="error">Error fetching results.</p>';
            } finally {
                searchLoader.style.display = 'none';
            }
        });

        // Allow pressing Enter to search
        searchInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                searchBtn.click();
            }
        });

        // Sync Anime
        syncBtn.addEventListener('click', async () => {
            const animeId = selectedAnimeIdInput.value;
            const episode = episodeInput.value;

            // Get selected users
            const selectedCheckboxes = document.querySelectorAll('input[name="selectedUsers"]:checked');
            const userIds = Array.from(selectedCheckboxes).map(cb => parseInt(cb.value));

            if (userIds.length === 0) {
                alert('Please select at least one user to sync.');
                return;
            }

            if (!animeId || !episode) {
                alert('Please select an anime and enter an episode.');
                return;
            }

            syncLoader.style.display = 'block';
            syncResult.innerHTML = '';
            syncBtn.disabled = true;

            try {
                const response = await fetch('/api/sync', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ animeId, episode, userIds })
                });

                const data = await response.json();

                if (data.error) {
                    syncResult.innerHTML = `<p class="error">${data.error}</p>`;
                } else {
                    let resultHtml = '<ul>';
                    data.results.forEach(res => {
                        if (res.success) {
                            resultHtml += `<li><span style="color: green;">✔</span> ${res.name}: Synced episode ${episode}</li>`;
                        } else {
                            resultHtml += `<li><span style="color: red;">✖</span> ${res.name}: Failed (${res.error})</li>`;
                        }
                    });
                    resultHtml += '</ul>';
                    syncResult.innerHTML = resultHtml;
                }
            } catch (err) {
                syncResult.innerHTML = '<p class="error">An error occurred during sync.</p>';
            } finally {
                syncLoader.style.display = 'none';
                syncBtn.disabled = false;
            }
        });
    </script>
</body>
</html>
